{
  "name": "emitter",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/emitter/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/emitter",
        "main": "apps/emitter/src/main.ts",
        "tsConfig": "apps/emitter/tsconfig.app.json",
        "assets": []
      }
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "emitter:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": { "buildTarget": "emitter:build" },
        "production": { "buildTarget": "emitter:build" }
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../coverage/apps/emitter"
      }
    }
  }
}
